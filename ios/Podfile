platform :ios, '13.0'

# Intentamos cargar la configuración de Flutter, si no existe, no rompemos el build
begin
  load File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'generated_plugin_registrant.rb')
rescue LoadError
  puts "Aviso: Archivos de Flutter no encontrados todavía. Continuando..."
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Solo instalamos si el método existe
  if respond_to?(:flutter_install_all_ios_pods)
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Solo aplicamos settings si Flutter ya cargó sus métodos
    flutter_additional_ios_build_settings(target) if respond_to?(:flutter_additional_ios_build_settings)
    
    target.build_configurations.each do |config|
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'PERMISSION_NOTIFICATIONS=1']
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end